<IfModule mod_rewrite.c>
    RewriteEngine On

    # If deploying this repository directly under a web path (e.g. /aiproject),
    # force all requests through the public front controller.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]

</IfModule>
